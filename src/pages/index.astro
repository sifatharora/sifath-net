---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const researchProjects = await getCollection('research');

function getWeekNumber(title: string) {
  const match = title.match(/^Week (\d+)/);
  return match ? Number(match[1]) : null;
}

const journalPosts = allPosts
  .filter((p) => p.data.category === 'dentistry')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = journalPosts[0];
const recent = journalPosts.slice(0, 4);
const latestWeek = latest ? getWeekNumber(latest.data.title) : null;
const weekCount = journalPosts.reduce((max, post) => {
  const week = getWeekNumber(post.data.title);
  return week && week > max ? week : max;
}, 0);
---

<Layout
  title="Home"
  description="Sifath Arora — freshman at Redmond High School exploring dentistry through research, chemistry, and community service."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-main">
        <p class="hero-greeting">Hi</p>
        <h1>Sifath Arora</h1>
        <p class="hero-lead">
          Freshman at Redmond High exploring dentistry — one journal entry at a time.
        </p>
        <div class="hero-meta">
          <span class="meta-chip">Week {weekCount} of the journal</span>
          <span class="meta-chip">Chemistry · Biology · Service</span>
        </div>
        <SocialLinks />
      </div>

      {latest && (
        <a href={`/blog/${latest.slug}`} class="featured-card">
          <span class="featured-label">Latest entry</span>
          <h2>{latest.data.title.replace(/^Week \d+ – /, '')}</h2>
          <p>{latest.data.description}</p>
          <span class="featured-link">
            Read week {latestWeek} &rarr;
          </span>
        </a>
      )}
    </div>
  </section>

  <section class="section stats-bar">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-num">{weekCount}</span>
        <span class="stat-label">Journal weeks</span>
      </div>
      <div class="stat">
        <span class="stat-num">{allPosts.length}</span>
        <span class="stat-label">Total posts</span>
      </div>
      <div class="stat">
        <span class="stat-num">4.0</span>
        <span class="stat-label">GPA</span>
      </div>
      <div class="stat">
        <span class="stat-num">{researchProjects.length}</span>
        <span class="stat-label">Research projects</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="highlight-card">
        <div class="highlight-content">
          <p class="section-label">Project</p>
          <h2>Care Collective</h2>
          <p>
            A community initiative I founded to collect and distribute dental care supplies
            to families who need them — turning oral health access into something tangible.
          </p>
        </div>
        <a href="/research/care-collective" class="highlight-link">Learn more &rarr;</a>
      </div>
    </div>
  </section>

  {recent.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <div>
            <p class="section-label">Dental journal</p>
            <h2>Recent weeks</h2>
          </div>
          <a href="/blog" class="btn-text">All posts &rarr;</a>
        </div>
        <ul class="journal-grid">
          {recent.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="journal-card">
                <span class="journal-week">Week {getWeekNumber(post.data.title) ?? '—'}</span>
                <span class="journal-title">{post.data.title.replace(/^Week \d+ – /, '')}</span>
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <p class="section-label">Explore</p>
      <nav class="explore-nav" aria-label="Site sections">
        <a href="/blog" class="explore-link">
          <span class="explore-name">Blog</span>
          <span class="explore-desc">Weekly dental journal &amp; writing</span>
        </a>
        <a href="/research" class="explore-link">
          <span class="explore-name">Research</span>
          <span class="explore-desc">Capstone projects &amp; Care Collective</span>
        </a>
        <a href="/books" class="explore-link">
          <span class="explore-name">Books</span>
          <span class="explore-desc">Science, health &amp; culture reviews</span>
        </a>
        <a href="/about" class="explore-link">
          <span class="explore-name">About</span>
          <span class="explore-desc">Story, activities &amp; resume</span>
        </a>
      </nav>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: clamp(3.5rem, 8vw, 5.5rem) 0 clamp(2.5rem, 5vw, 3.5rem);
    background:
      radial-gradient(ellipse 70% 50% at 100% 0%, rgba(220, 238, 233, 0.6) 0%, transparent 55%),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .hero-main h1 {
    margin-bottom: 0.75rem;
  }

  .hero-greeting {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--accent-dark);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .hero-lead {
    font-size: 1.08rem;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 32ch;
    margin-bottom: 1.25rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .meta-chip {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    background: var(--accent-light);
    color: var(--accent-dark);
  }

  .featured-card {
    display: block;
    padding: 1.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .featured-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    border-color: #c8d9d4;
  }

  .featured-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.65rem;
  }

  .featured-card h2 {
    font-size: 1.45rem;
    margin-bottom: 0.65rem;
    line-height: 1.25;
  }

  .featured-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .featured-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
  }

  .featured-card:hover .featured-link {
    color: var(--accent-dark);
  }

  .stats-bar {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    text-align: center;
  }

  .stat-num {
    display: block;
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-dark);
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .stat-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .highlight-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.25rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .highlight-content h2 {
    margin-bottom: 0.5rem;
    font-size: 1.65rem;
  }

  .highlight-content p {
    color: var(--text-muted);
    margin: 0;
    max-width: 48ch;
    line-height: 1.65;
  }

  .highlight-link {
    flex-shrink: 0;
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    color: var(--accent);
    white-space: nowrap;
  }

  .highlight-link:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .section-head h2 {
    margin: 0;
  }

  .journal-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  .journal-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.15rem 1.35rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s, border-color 0.15s;
  }

  .journal-card:hover {
    background: var(--bg-soft);
    border-color: #c8d9d4;
  }

  .journal-week {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .journal-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
  }

  .journal-card:hover .journal-title {
    color: var(--accent-dark);
  }

  .journal-card time {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .explore-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: 1.25rem;
  }

  .explore-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    transition: background 0.15s;
  }

  .explore-link:nth-child(2n) {
    border-right: none;
  }

  .explore-link:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .explore-link:hover {
    background: var(--bg-soft);
  }

  .explore-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .explore-link:hover .explore-name {
    color: var(--accent-dark);
  }

  .explore-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .highlight-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .journal-grid {
      grid-template-columns: 1fr;
    }

    .explore-nav {
      grid-template-columns: 1fr;
    }

    .explore-link {
      border-right: none;
    }

    .explore-link:nth-last-child(-n+2) {
      border-bottom: 1px solid var(--border);
    }

    .explore-link:last-child {
      border-bottom: none;
    }
  }

  @media (max-width: 640px) {
    .section-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
