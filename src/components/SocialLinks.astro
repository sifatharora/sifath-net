---
import { site } from '../site';

interface Props {
  variant?: 'inline' | 'stacked';
}

const { variant = 'inline' } = Astro.props;
---

<div class:list={['social-links', variant]}>
  <a href={`mailto:${site.email}`} class="social-link">
    <span class="social-label">Email</span>
    <span class="social-value">{site.email}</span>
  </a>
  <a
    href={site.linkedin}
    class="social-link"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="social-label">LinkedIn</span>
    <span class="social-value">Connect with me</span>
  </a>
</div>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .social-links.stacked {
    flex-direction: column;
    gap: 0.65rem;
  }

  .social-link {
    display: inline-flex;
    flex-direction: column;
    gap: 0.1rem;
    text-decoration: none;
    color: inherit;
    transition: color 0.15s;
  }

  .social-link:hover {
    color: var(--accent-dark);
  }

  .social-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .social-value {
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .social-link:hover .social-value {
    color: var(--accent-dark);
    text-decoration: underline;
  }
</style>
